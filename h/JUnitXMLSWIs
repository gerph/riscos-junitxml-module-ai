#ifndef _JUnitXMLSWIs_H
#define _JUnitXMLSWIs_H

/* Flag definitions */
#define JUnitXML_Create_FilenameGiven  (1 << 0)

#define JUnitXML_TestSuite_OpMask      0x0F
#define JUnitXML_TestSuite_OpCreate    0
#define JUnitXML_TestSuite_OpClose     1
#define JUnitXML_TestSuite_OpUpdate    2
#define JUnitXML_TestSuite_OpProperty  3

#define JUnitXML_TestSuite_PackageSupplied   (1 << 4)
#define JUnitXML_TestSuite_TSMask            (3 << 5)
#define JUnitXML_TestSuite_TSShift           5
#define JUnitXML_TestSuite_TSCurrent         0
#define JUnitXML_TestSuite_TSRiscOS          (1 << 5)
#define JUnitXML_TestSuite_TSUnix            (2 << 5)
#define JUnitXML_TestSuite_TSISO8601         (3 << 5)
#define JUnitXML_TestSuite_DurationPresent   (1 << 7)

#define JUnitXML_TestCase_OpMask       0x0F
#define JUnitXML_TestCase_OpCreate     0
#define JUnitXML_TestCase_OpClose      1
#define JUnitXML_TestCase_OpUpdate     2

#define JUnitXML_TestCase_StatusMask   (0x0F << 4)
#define JUnitXML_TestCase_StatusShift  4
#define JUnitXML_TestCase_StatusNone   (0 << 4)
#define JUnitXML_TestCase_StatusSuccess (1 << 4)
#define JUnitXML_TestCase_StatusFailure (2 << 4)
#define JUnitXML_TestCase_StatusError  (3 << 4)
#define JUnitXML_TestCase_StatusSkipped (4 << 4)

#define JUnitXML_TestCase_ErrorBlock   (1 << 8)

#define JUnitXML_Close_FilenameGiven   (1 << 0)

#endif /* _JUnitXMLSWIs_H */
